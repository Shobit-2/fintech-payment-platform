// ============================================================================
// Jenkinsfile - Digital Payment Processing Platform CI/CD Pipeline
//
// Declarative Pipeline syntax (vs. Scripted Pipeline): declarative is
// structured, easier to read, and has built-in support for stage
// visualization in the Jenkins UI (Blue Ocean / stage view). We use it
// throughout this project.
//
// STAGES IMPLEMENTED SO FAR: Checkout, Build & Test, SCA + SBOM, SonarQube,
// Docker Build, Trivy Scan
// Later steps will add: ECR push, EKS deploy, ArgoCD sync, DAST, smoke
// test, canary/blue-green.
// ============================================================================

pipeline {
    agent any

    environment {
        JAVA_HOME = '/usr/lib/jvm/java-21-openjdk-amd64'
        PATH      = "${JAVA_HOME}/bin:${env.PATH}"

        // Image tag = build number + short commit SHA (e.g. "42-a1b2c3d").
        // Traceable and immutable - unlike 'latest', this tag is never
        // overwritten, essential for reliable rollback later.
        IMAGE_NAME = 'fintech-payment-platform'
        IMAGE_TAG  = "${env.BUILD_NUMBER}-${env.GIT_COMMIT.take(7)}"
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        // TEMPORARILY raised from 30 to 60 minutes for the one-time full
        // NVD database sync (Stage 3). Lower back down once confirmed the
        // local cache is warm and subsequent runs are fast.
        timeout(time: 60, unit: 'MINUTES')
    }

    stages {

        // ====================================================================
        // STAGE 1: SOURCE CODE CHECKOUT
        // ====================================================================
        stage('Checkout') {
            steps {
                echo "Checked out branch: ${env.GIT_BRANCH}"
                echo "Commit: ${env.GIT_COMMIT}"
                sh 'ls -la application/'
            }
        }

        // ====================================================================
        // STAGE 2: BUILD + TEST (CI)
        // ====================================================================
        stage('Build & Test') {
            steps {
                dir('application') {
                    sh '''
                        echo "Using JDK:"
                        java -version
                        echo "Using Maven:"
                        mvn -version

                        mvn clean verify
                    '''
                }
            }
            post {
                always {
                    junit testResults: 'application/target/surefire-reports/*.xml,application/target/failsafe-reports/*.xml',
                          allowEmptyResults: true

                    archiveArtifacts artifacts: 'application/target/*.jar',
                                      allowEmptyArchive: true,
                                      fingerprint: true
                }
            }
        }

        // ====================================================================
        // STAGE 3: SOFTWARE COMPOSITION ANALYSIS + SBOM
        // ====================================================================
        stage('SCA + SBOM') {
            steps {
                dir('application') {
                    withCredentials([string(credentialsId: 'nvd-api-key', variable: 'NVD_API_KEY')]) {
                        sh '''
                            mvn org.owasp:dependency-check-maven:check -DnvdApiKey=$NVD_API_KEY
                            mvn org.cyclonedx:cyclonedx-maven-plugin:makeAggregateBom
                        '''
                    }
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'application/target/dependency-check-report.html,application/target/bom.xml',
                                      allowEmptyArchive: true,
                                      fingerprint: true
                }
            }
        }

        // ====================================================================
        // STAGE 4: SONARQUBE CLOUD STATIC ANALYSIS + QUALITY GATE
        // ====================================================================
        stage('SonarQube Analysis') {
            steps {
                dir('application') {
                    withCredentials([string(credentialsId: 'sonarcloud-token', variable: 'SONAR_TOKEN')]) {
                        sh '''
                            mvn org.sonarsource.scanner.maven:sonar-maven-plugin:sonar \
                                -Dsonar.organization=Shobit-2 \
                                -Dsonar.projectKey=Shobit-2_fintech-payment-platform \
                                -Dsonar.host.url=https://sonarcloud.io \
                                -Dsonar.token=$SONAR_TOKEN \
                                -Dsonar.qualitygate.wait=true
                        '''
                    }
                }
            }
        }

        // ====================================================================
        // STAGE 5: DOCKER BUILD
        // ====================================================================
        stage('Docker Build') {
            steps {
                dir('application') {
                    sh '''
                        docker build -t $IMAGE_NAME:$IMAGE_TAG -t $IMAGE_NAME:latest .
                        echo "Built image:"
                        docker images $IMAGE_NAME
                    '''
                }
            }
        }

        // ====================================================================
        // STAGE 6: TRIVY CONTAINER SECURITY SCAN
        // Scans the image built in Stage 5 - the ENTIRE image (OS packages,
        // system libraries), not just app dependencies (that's Stage 3).
        // --exit-code 1 fails this stage if CRITICAL/HIGH findings exist.
        // ====================================================================
        stage('Trivy Scan') {
            steps {
                dir('application') {
                    sh '''
                        trivy image --format table $IMAGE_NAME:$IMAGE_TAG

                        trivy image --format json --output trivy-report.json $IMAGE_NAME:$IMAGE_TAG

                        trivy image --exit-code 1 --severity CRITICAL,HIGH $IMAGE_NAME:$IMAGE_TAG
                    '''
                }
            }
            post {
                always {
                    archiveArtifacts artifacts: 'application/trivy-report.json',
                                      allowEmptyArchive: true,
                                      fingerprint: true
                }
            }
        }
    }

    post {
        success {
            echo "✅ Build & Test stage passed."
        }
        failure {
            echo "❌ Pipeline failed - check the stage logs above for details."
        }
    }
}